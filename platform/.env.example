# Postgres connection. DATABASE_URL is the OWNER role (neondb_owner) — used for
# migrations/admin only. The APP must connect as APP_DATABASE_URL, a dedicated
# role (`nayahr_app`) that does NOT bypass RLS, or tenant isolation is silently
# disabled (Neon's default owner role has BYPASSRLS). See sql/0015_app_role_grants.sql.
DATABASE_URL=postgres://neondb_owner:PASSWORD@HOST/DB?sslmode=require
APP_DATABASE_URL=postgres://nayahr_app:PASSWORD@HOST/DB?sslmode=require

# ---- Clerk (Phase 2 auth) ----
# From the Clerk dashboard -> API keys.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxx
CLERK_SECRET_KEY=sk_test_xxx
# Where Clerk routes for auth + where to land after.
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/people
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/people

# ---- Anthropic (Phase 3 AI assistant) ----
# Server-side only (no NEXT_PUBLIC) — the key never reaches the browser.
ANTHROPIC_API_KEY=sk-ant-xxx

# ---- Production ----
# Public base URL of the deployed app; used as the redirect target for employee
# invitation emails. Defaults to the request host if unset. Add this same URL to
# Clerk's allowed redirect URLs.
# APP_URL=https://app.nayahr.com
# Postgres pool size per serverless instance (keep small). Defaults to 5.
# PG_POOL_MAX=5

# ---- Dev-only scope testing ----
# Set DEV_ROLE to view the org/team/self scopes without creating 3 Clerk users.
# Ignored in production. The demo tenant is read from platform/.dev-session.json.
# DEV_ROLE=manager          # owner | hr_admin | manager | employee
# DEMO_TENANT_ID=           # optional override of the demo tenant id
